# Anthropic API key for Claude generation
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the default Claude model
# CLAUDE_MODEL=claude-haiku-4-5

# Where ChromaDB persists its data (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_data

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking config (tokens; all-MiniLM-L6-v2 has a 256-token max input)
CHUNK_SIZE=200
CHUNK_OVERLAP=30

# Retrieval config
TOP_K=4

# CORS: comma-separated list of allowed origins for the React frontend
ALLOWED_ORIGINS=http://localhost:5173
